<button onclick="{{generarDatosDePrueba(10000)}}">Generar Datos de Prueba</button>
<h4>Cantidad de datos en memoria: {{usuarios.length}} sin virtual scroll</h4>
<div if="{{usuarios.length > 0}}" style="border:1px solid #ccc; height:300px; overflow-y:scroll">
    <div style="{{heightAutoScroll()}}">
        <ul id="lista-benchmark" loop="{{usuario in usuarios}}">
            <li>
                <span class="id">#{{usuario.id}}</span>
                <strong>{{usuario.nombre}}</strong>
                <span class="badge {{usuario.estado}}">{{usuario.estado}}</span>
                <code>{{usuario.hash}}</code>
            </li>
        </ul>
    </div>
</div>
